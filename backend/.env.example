# ===== Backend Environment Variables =====
# Copy this file to .env and fill in your values

# MongoDB
MONGO_URI=mongodb+srv://<user>:<password>@cluster.mongodb.net/?appName=AppName

# Server
PORT=3001
JWT_SECRET=your_jwt_secret_here

# Google OAuth2
GOOGLE_CLIENT_ID=your_google_client_id
GOOGLE_CLIENT_SECRET=your_google_client_secret

# Flutterwave
FLUTTERWAVE_PUBLIC_KEY=FLWPUBK_TEST-xxxxxxxxxxxx-X
FLUTTERWAVE_SECRET_KEY=FLWSECK_TEST-xxxxxxxxxxxx-X
FLW_WEBHOOK_SECRET=your_webhook_secret

# URLs
BACKEND_URL=http://localhost:3001
FRONTEND_URL=http://localhost:3000

# SMTP (Gmail App Password recommended)
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your@gmail.com
SMTP_PASS=your_app_password
SMTP_FROM_EMAIL=no-reply@yourdomain.com
